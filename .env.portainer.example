# Public origin used by the app, passkey ceremonies, and MCP metadata.
APP_URL=https://saatgut.example.com

# Required auth secret for sessions and passkey ceremony signing.
AUTH_SECRET=replace-with-a-long-random-secret

# WebAuthn/passkey relying-party settings.
# `WEBAUTHN_RP_ID` must be the hostname only, without scheme or port.
WEBAUTHN_RP_NAME=Saatgut
WEBAUTHN_RP_ID=saatgut.example.com
WEBAUTHN_ALLOWED_ORIGINS=https://saatgut.example.com

# Baseline request throttles.
API_RATE_LIMIT_PER_MINUTE=120
API_TOKEN_DEFAULT_RATE_LIMIT_PER_MINUTE=60

# Container media storage path and upload ceiling.
MEDIA_STORAGE_DIR=/app/var/media
MEDIA_MAX_UPLOAD_BYTES=5242880

# Browser origins allowed to call the MCP HTTP endpoint.
MCP_ALLOWED_ORIGINS=https://saatgut.example.com

# Compose-derived PostgreSQL settings.
POSTGRES_DB=saatgut
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password
APP_PORT=3000

# Optional image pins for Portainer.
SAATGUT_APP_IMAGE=ghcr.io/beisel-it/saatgut:latest
SAATGUT_DB_IMAGE=ghcr.io/beisel-it/saatgut-db:latest
