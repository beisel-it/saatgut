# Application URL for local development and container health checks.
APP_URL=http://localhost:3000

# Session/auth secret for local development.
AUTH_SECRET=replace-with-local-dev-secret

# WebAuthn/passkey relying party settings.
WEBAUTHN_RP_NAME=Saatgut
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3000

# Direct database connection for local host-based development.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/saatgut?schema=public

# Baseline per-minute request limits.
API_RATE_LIMIT_PER_MINUTE=120
API_TOKEN_DEFAULT_RATE_LIMIT_PER_MINUTE=60

# Comma-separated browser origins allowed to call the MCP HTTP endpoint.
MCP_ALLOWED_ORIGINS=http://localhost:3000

# Compose-friendly database defaults.
# These values are authoritative for Docker Compose and Portainer.
# `POSTGRES_PASSWORD` is reconciled back onto the persisted database role on every container start,
# so changing it here updates the runtime password even when the volume already exists.
POSTGRES_DB=saatgut
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
APP_PORT=3000
