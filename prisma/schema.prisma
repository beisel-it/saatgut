generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum WorkspaceVisibility {
  PRIVATE
  SHARED
}

enum MembershipRole {
  OWNER
  MEMBER
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum SpeciesCategory {
  VEGETABLE
  FRUIT
  HERB
  FLOWER
  OTHER
}

enum SeedQuantityUnit {
  SEEDS
  PACKETS
  GRAMS
}

enum StorageLightExposure {
  DARK
  INDIRECT
  BRIGHT
}

enum StorageMoistureLevel {
  DRY
  MODERATE
  HUMID
}

enum PlantingEventType {
  SOW_INDOORS
  SOW_OUTDOORS
  TRANSPLANT
  HARVEST
}

enum SeedBatchTransactionType {
  INITIAL_STOCK
  PLANTING_CONSUMPTION
  MANUAL_CORRECTION
  REVERSAL
}

enum PlantingJournalEntryType {
  OBSERVATION
  TASK_NOTE
  PEST_NOTE
  WEATHER_NOTE
  HARVEST_NOTE
  SEED_SAVED
}

enum ReminderTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

enum ReminderTaskSource {
  MANUAL
  CALENDAR
  JOURNAL
  QUALITY
  SYSTEM
}

enum ApiTokenScope {
  READ
  WRITE
  EXPORT
  ADMIN
}

enum PasskeyDeviceType {
  SINGLE_DEVICE
  MULTI_DEVICE
}

enum MediaAssetKind {
  VARIETY_REPRESENTATIVE
  SEED_BATCH_PACKET
  SEED_BATCH_REFERENCE
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String?
  webauthnUserId String?     @unique
  isActive     Boolean       @default(true)
  role         UserRole      @default(MEMBER)
  memberships  Membership[]
  passkeys      PasskeyCredential[]
  auditLogs    AuditLog[]
  sentInvites  UserInvite[]  @relation("SentInvites")
  createdReminderTasks ReminderTask[] @relation("CreatedReminderTasks")
  assignedReminderTasks ReminderTask[] @relation("AssignedReminderTasks")
  apiTokens    ApiToken[]    @relation("CreatedApiTokens")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  visibility      WorkspaceVisibility @default(PRIVATE)
  memberships     Membership[]
  species         Species[]
  varieties       Variety[]
  seedBatches     SeedBatch[]
  germinationTests GerminationTest[]
  seedBatchTransactions SeedBatchTransaction[]
  growingProfiles GrowingProfile[]
  plantingEvents  PlantingEvent[]
  journalEntries  PlantingJournalEntry[]
  reminderTasks   ReminderTask[]
  apiTokens       ApiToken[]
  invites         UserInvite[]
  auditLogs       AuditLog[]
  mediaAssets     MediaAsset[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(MEMBER)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([userId, workspaceId])
}

model Species {
  id                   String          @id @default(cuid())
  workspaceId          String
  commonName           String
  latinName            String?
  category             SpeciesCategory @default(VEGETABLE)
  germinationNotes     String?
  preferredLocation    String?
  companionPlantingNotes String?
  notes                String?
  workspace            Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  varieties            Variety[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Variety {
  id                    String            @id @default(cuid())
  workspaceId           String
  speciesId             String
  name                  String
  description           String?
  heirloom              Boolean           @default(false)
  tags                  String[]          @default([])
  germinationNotes      String?
  preferredLocation     String?
  companionPlantingNotes String?
  notes                 String?
  workspace             Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  species               Species           @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  synonyms              VarietySynonym[]
  seedBatches           SeedBatch[]
  cultivationRule       CultivationRule?
  plantingEvents        PlantingEvent[]
  journalEntries        PlantingJournalEntry[]
  reminderTasks         ReminderTask[]
  mediaAssets           MediaAsset[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([workspaceId, name])
}

model VarietySynonym {
  id        String   @id @default(cuid())
  varietyId String
  name      String
  variety   Variety  @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([varietyId, name])
}

model SeedBatch {
  id              String           @id @default(cuid())
  workspaceId     String
  varietyId       String
  source          String?
  harvestYear     Int?
  quantity        Decimal          @db.Decimal(10, 2)
  unit            SeedQuantityUnit @default(SEEDS)
  storageLocation String?
  storageTemperatureC Decimal?     @db.Decimal(4, 1)
  storageHumidityPercent Int?
  storageLightExposure StorageLightExposure?
  storageMoistureLevel StorageMoistureLevel?
  storageContainer String?
  storageQualityCheckedAt DateTime?
  notes           String?
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variety         Variety          @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  plantingEvents  PlantingEvent[]
  journalEntries  PlantingJournalEntry[]
  germinationTests GerminationTest[]
  stockTransactions SeedBatchTransaction[]
  reminderTasks   ReminderTask[]
  mediaAssets     MediaAsset[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workspaceId, varietyId])
}

model MediaAsset {
  id               String         @id @default(cuid())
  workspaceId      String
  varietyId        String?
  seedBatchId      String?
  kind             MediaAssetKind
  originalFilename String
  storageKey       String         @unique
  mimeType         String
  byteSize         Int
  altText          String?
  caption          String?
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variety          Variety?       @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  seedBatch        SeedBatch?     @relation(fields: [seedBatchId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([varietyId, kind])
  @@index([workspaceId, kind, createdAt])
  @@index([seedBatchId, kind, createdAt])
}

model GrowingProfile {
  id             String          @id @default(cuid())
  workspaceId    String
  name           String
  lastFrostDate  DateTime
  firstFrostDate DateTime
  phenologyStage String?
  phenologyObservedAt DateTime?
  phenologyNotes String?
  notes          String?
  isActive       Boolean         @default(false)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plantingEvents PlantingEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workspaceId, isActive])
}

model CultivationRule {
  id                     String   @id @default(cuid())
  varietyId              String   @unique
  sowIndoorsStartWeeks   Int?
  sowIndoorsEndWeeks     Int?
  sowOutdoorsStartWeeks  Int?
  sowOutdoorsEndWeeks    Int?
  transplantStartWeeks   Int?
  transplantEndWeeks     Int?
  harvestStartDays       Int?
  harvestEndDays         Int?
  spacingCm              Int?
  successionIntervalDays Int?
  variety                Variety  @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PlantingEvent {
  id              String            @id @default(cuid())
  workspaceId     String
  varietyId       String
  seedBatchId     String?
  growingProfileId String?
  type            PlantingEventType
  plannedDate     DateTime?
  actualDate      DateTime?
  quantityUsed    Decimal?          @db.Decimal(10, 2)
  locationNote    String?
  notes           String?
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variety         Variety           @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  seedBatch       SeedBatch?        @relation(fields: [seedBatchId], references: [id], onDelete: SetNull)
  growingProfile  GrowingProfile?   @relation(fields: [growingProfileId], references: [id], onDelete: SetNull)
  journalEntries  PlantingJournalEntry[]
  stockTransactions SeedBatchTransaction[]
  reminderTasks   ReminderTask[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workspaceId, plannedDate])
}

model GerminationTest {
  id              String           @id @default(cuid())
  workspaceId     String
  seedBatchId     String
  testedAt        DateTime
  sampleSize      Int
  germinatedCount Int
  germinationRate Decimal          @db.Decimal(5, 2)
  notes           String?
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  seedBatch       SeedBatch        @relation(fields: [seedBatchId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workspaceId, testedAt])
  @@index([seedBatchId, testedAt])
}

model SeedBatchTransaction {
  id                String                    @id @default(cuid())
  workspaceId       String
  seedBatchId       String
  plantingEventId   String?
  type              SeedBatchTransactionType
  quantityDelta     Decimal                   @db.Decimal(10, 2)
  quantityBefore    Decimal                   @db.Decimal(10, 2)
  quantityAfter     Decimal                   @db.Decimal(10, 2)
  effectiveDate     DateTime
  reason            String?
  reversalOfId      String?
  workspace         Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  seedBatch         SeedBatch                 @relation(fields: [seedBatchId], references: [id], onDelete: Cascade)
  plantingEvent     PlantingEvent?            @relation(fields: [plantingEventId], references: [id], onDelete: SetNull)
  createdAt         DateTime                  @default(now())

  @@index([workspaceId, effectiveDate])
  @@index([seedBatchId, effectiveDate])
  @@index([reversalOfId])
}

model PlantingJournalEntry {
  id              String                   @id @default(cuid())
  workspaceId     String
  varietyId       String?
  seedBatchId     String?
  plantingEventId String?
  entryType       PlantingJournalEntryType
  title           String
  details         String?
  entryDate       DateTime
  quantity        Decimal?                 @db.Decimal(10, 2)
  unit            SeedQuantityUnit?
  tags            String[]                 @default([])
  workspace       Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variety         Variety?                 @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  seedBatch       SeedBatch?               @relation(fields: [seedBatchId], references: [id], onDelete: SetNull)
  plantingEvent   PlantingEvent?           @relation(fields: [plantingEventId], references: [id], onDelete: SetNull)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([workspaceId, entryDate])
}

model UserInvite {
  id              String         @id @default(cuid())
  workspaceId     String
  email           String
  role            MembershipRole @default(MEMBER)
  invitedByUserId String
  tokenHash       String         @unique
  status          InviteStatus   @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedByUser   User           @relation("SentInvites", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([workspaceId, email, status])
}

model PasskeyCredential {
  id           String            @id @default(cuid())
  userId       String
  credentialId String            @unique
  publicKey    Bytes
  counter      Int
  transports   String[]          @default([])
  deviceType   PasskeyDeviceType
  backedUp     Boolean           @default(false)
  lastUsedAt   DateTime?
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, createdAt])
}

model ReminderTask {
  id              String             @id @default(cuid())
  workspaceId     String
  createdByUserId String
  assignedUserId  String?
  varietyId       String?
  seedBatchId     String?
  plantingEventId String?
  title           String
  details         String?
  dueDate         DateTime
  status          ReminderTaskStatus @default(PENDING)
  source          ReminderTaskSource @default(MANUAL)
  tags            String[]           @default([])
  completedAt     DateTime?
  dismissedAt     DateTime?
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser   User               @relation("CreatedReminderTasks", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignedUser    User?              @relation("AssignedReminderTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)
  variety         Variety?           @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  seedBatch       SeedBatch?         @relation(fields: [seedBatchId], references: [id], onDelete: SetNull)
  plantingEvent   PlantingEvent?     @relation(fields: [plantingEventId], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([workspaceId, dueDate])
  @@index([workspaceId, status, dueDate])
  @@index([assignedUserId, status, dueDate])
}

model ApiToken {
  id                 String          @id @default(cuid())
  workspaceId        String
  createdByUserId    String
  name               String
  tokenHash          String          @unique
  tokenPrefix        String
  scopes             ApiTokenScope[]
  rateLimitPerMinute Int             @default(120)
  lastUsedAt         DateTime?
  expiresAt          DateTime?
  revokedAt          DateTime?
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser      User            @relation("CreatedApiTokens", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([workspaceId, revokedAt, createdAt])
  @@index([createdByUserId, revokedAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  payload     Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser   User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
}
