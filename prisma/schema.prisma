generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum WorkspaceVisibility {
  PRIVATE
  SHARED
}

enum MembershipRole {
  OWNER
  MEMBER
  VIEWER
}

enum SpeciesCategory {
  VEGETABLE
  FRUIT
  HERB
  FLOWER
  OTHER
}

enum SeedQuantityUnit {
  SEEDS
  PACKETS
  GRAMS
}

enum PlantingEventType {
  SOW_INDOORS
  SOW_OUTDOORS
  TRANSPLANT
  HARVEST
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  role         UserRole      @default(MEMBER)
  memberships  Membership[]
  auditLogs    AuditLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  visibility      WorkspaceVisibility @default(PRIVATE)
  memberships     Membership[]
  species         Species[]
  varieties       Variety[]
  seedBatches     SeedBatch[]
  growingProfiles GrowingProfile[]
  plantingEvents  PlantingEvent[]
  auditLogs       AuditLog[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  workspaceId String
  role        MembershipRole @default(MEMBER)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([userId, workspaceId])
}

model Species {
  id          String          @id @default(cuid())
  workspaceId String
  commonName  String
  latinName   String?
  category    SpeciesCategory @default(VEGETABLE)
  notes       String?
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  varieties   Variety[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Variety {
  id              String            @id @default(cuid())
  workspaceId     String
  speciesId       String
  name            String
  description     String?
  heirloom        Boolean           @default(false)
  notes           String?
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  species         Species           @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  synonyms        VarietySynonym[]
  seedBatches     SeedBatch[]
  cultivationRule CultivationRule?
  plantingEvents  PlantingEvent[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workspaceId, name])
}

model VarietySynonym {
  id        String   @id @default(cuid())
  varietyId String
  name      String
  variety   Variety  @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([varietyId, name])
}

model SeedBatch {
  id              String           @id @default(cuid())
  workspaceId     String
  varietyId       String
  source          String?
  harvestYear     Int?
  quantity        Decimal          @db.Decimal(10, 2)
  unit            SeedQuantityUnit @default(SEEDS)
  storageLocation String?
  notes           String?
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variety         Variety          @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  plantingEvents  PlantingEvent[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([workspaceId, varietyId])
}

model GrowingProfile {
  id             String          @id @default(cuid())
  workspaceId    String
  name           String
  lastFrostDate  DateTime
  firstFrostDate DateTime
  notes          String?
  isActive       Boolean         @default(false)
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plantingEvents PlantingEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([workspaceId, isActive])
}

model CultivationRule {
  id                     String   @id @default(cuid())
  varietyId              String   @unique
  sowIndoorsStartWeeks   Int?
  sowIndoorsEndWeeks     Int?
  sowOutdoorsStartWeeks  Int?
  sowOutdoorsEndWeeks    Int?
  transplantStartWeeks   Int?
  transplantEndWeeks     Int?
  harvestStartDays       Int?
  harvestEndDays         Int?
  spacingCm              Int?
  successionIntervalDays Int?
  variety                Variety  @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model PlantingEvent {
  id              String            @id @default(cuid())
  workspaceId     String
  varietyId       String
  seedBatchId     String?
  growingProfileId String?
  type            PlantingEventType
  plannedDate     DateTime?
  actualDate      DateTime?
  quantityUsed    Decimal?          @db.Decimal(10, 2)
  locationNote    String?
  notes           String?
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variety         Variety           @relation(fields: [varietyId], references: [id], onDelete: Cascade)
  seedBatch       SeedBatch?        @relation(fields: [seedBatchId], references: [id], onDelete: SetNull)
  growingProfile  GrowingProfile?   @relation(fields: [growingProfileId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([workspaceId, plannedDate])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  payload     Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser   User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
}
